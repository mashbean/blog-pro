---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";

// ── 19 篇文章規格 ───────────────────────────────────────────────
// 對應 dissertation-outline.md 的五部結構 + prompt 對映
type ArticleSpec = {
  no: string;          // 01..19
  prompt: string;      // A1..F3
  slug: string;        // matches reports/argmaps id (or stub for unpublished)
  title: string;       // 中文標題
  part: 1 | 2 | 3 | 4 | 5;
  chapter: string;     // 對應章節編號
};

const articles: ArticleSpec[] = [
  { no: "01", prompt: "A1", slug: "2026-05-02-accountability-without-identification", title: "可問責不以實名為前提", part: 1, chapter: "Ch 3.4" },
  { no: "02", prompt: "A3", slug: "2026-05-03-civic-proof-concept-positioning", title: "公民證明的概念定位", part: 1, chapter: "Ch 2.2" },
  { no: "03", prompt: "B1", slug: "2026-05-03-digital-association-empirical-test", title: "結社自由 × 數位身分：三道牆的經驗檢驗", part: 3, chapter: "Ch 8.3" },
  { no: "04", prompt: "C1", slug: "2026-05-04-pseudonymous-participation-legal", title: "假名式公共參與的法理基礎", part: 3, chapter: "Ch 8.2" },
  { no: "05", prompt: "C2", slug: "2026-05-05-sybil-resistance-cost-benefit", title: "唯一性證明的成本-收益矩陣", part: 3, chapter: "Ch 8.1" },
  { no: "06", prompt: "C3", slug: "2026-05-05-civic-burden-redistribution", title: "Civic Burden 的重新分配", part: 2, chapter: "Ch 6.6" },
  { no: "07", prompt: "D2", slug: "2026-05-05-passport-rooted-paradox", title: "護照根的不可能性", part: 2, chapter: "Ch 5.4" },
  { no: "08", prompt: "D3", slug: "2026-05-06-dns-vs-identity-trust-roots", title: "DNS 信任根 vs 身分信任根", part: 4, chapter: "Ch 11.4" },
  { no: "09", prompt: "D1", slug: "09-bankid-nordic-monopoly-democracy", title: "北歐 BankID 模式：商業壟斷與民主韌性", part: 2, chapter: "Ch 4.4" },
  { no: "10", prompt: "B2", slug: "10-digital-identity-civic-action-quant", title: "跨國定量：身分制度 × 結社自由", part: 2, chapter: "Ch 4.6" },
  { no: "11", prompt: "E1", slug: "11-wallet-as-essential-facility", title: "Wallet as Essential Facility — 反壟斷套用", part: 4, chapter: "Ch 10" },
  { no: "12", prompt: "E2", slug: "12-no-phone-home-engineering-economics", title: "No-Phone-Home 的工程經濟學", part: 4, chapter: "Ch 11.3" },
  { no: "13", prompt: "E3", slug: "13-structural-slippage-prevention", title: "年齡驗證與結構性滑坡的預防設計", part: 3, chapter: "Ch 7" },
  { no: "14", prompt: "E4", slug: "14-cross-jurisdictional-redress-gap", title: "跨法域救濟的空白", part: 4, chapter: "Ch 12.3" },
  { no: "15", prompt: "E5", slug: "15-civic-proof-inclusion-rights", title: "Civic Proof Inclusion Rights — 無 wallet 替代路徑", part: 5, chapter: "Ch 14.4" },
  { no: "16", prompt: "F1", slug: "16-civic-ai-agent-delegation-limits", title: "AI 代理在公民行動的制度極限", part: 3, chapter: "Ch 9" },
  { no: "17", prompt: "F2", slug: "17-civic-receipts-provenance", title: "Civic Receipts 與證據鏈", part: 3, chapter: "Ch 9.3" },
  { no: "18", prompt: "F3", slug: "18-selective-disclosure-ux-failure", title: "Selective Disclosure 的 UX 認知極限", part: 4, chapter: "Ch 10.3" },
  { no: "19", prompt: "A2", slug: "19-public-realm-political-philosophy", title: "公共領域的政治哲學基礎", part: 1, chapter: "Ch 2.5" },
];

// ── 五部 = 五母命題 ─────────────────────────────────────────────
type PartSpec = { id: 1 | 2 | 3 | 4 | 5; label: string; title: string; thesis: string };
const parts: PartSpec[] = [
  {
    id: 1,
    label: "P₁ 概念基礎",
    title: "Foundations — 公民證明作為概念工程",
    thesis: "公民證明 ≜ ⟨𝒩, ℱ, ℬ⟩。它不是 KYC 等同物或 SBT 的重命名，而是介於存在性 ID 與資格性 ID 之間的第三類——由規範差異矩陣 𝒩 + 形式範圍 ℱ + 哲學基礎 ℬ 三件定義。",
  },
  {
    id: 2,
    label: "P₂ 經驗比較",
    title: "Comparative Empirics — 五個國家群集的覆蓋缺口",
    thesis: "在五個國家群集（英澳 / 歐盟瑞士 / 美國州級 / 北歐 BankID / 全球南方）與護照根場域中，現存制度都在 𝒩 規範矩陣的至少一個維度上失敗。經驗證據顯示「重命名」分類不成立。",
  },
  {
    id: 3,
    label: "P₃ 規範壓力測試",
    title: "Normative Stress Tests — 三條測試線",
    thesis: "對年齡驗證（結構性滑坡）/ 假名與唯一性（結社自由與 Sybil 抗性）/ AI 委任（公民行動的制度極限）三條規範測試線，公民證明三件式 ⟨𝒩, ℱ, ℬ⟩ 必須通過合取必要條件 + 概率退化邊界。",
  },
  {
    id: 4,
    label: "P₄ 制度與基礎設施",
    title: "Institutional & Infrastructural Design — 三層基礎設施",
    thesis: "從發證壟斷到呈現壟斷（wallet/OS/browser as gatekeeper）→ 信任根與公共區塊鏈（DNS vs 身分根 + no-phone-home 經濟）→ 採購政治經濟（跨法域救濟空白）。基礎設施層的設計決定 ℱ 形式範圍能否落地。",
  },
  {
    id: 5,
    label: "P₅ 結論與政策議程",
    title: "Conclusion & Policy — Federated Trust-List Alliance",
    thesis: "結論：可問責不以實名為前提（A ⇐ P[U]）。政策：privacy-first baseline + Federated Trust-List Alliance + procurement sandbox + supplier diversity + civic proof inclusion rights（無 wallet 替代路徑）+ Indo-Pacific demo grants。",
  },
];

// ── 從 collection 中查找實際發佈狀態與核心公式 ─────────────────
const argmaps = await getCollection("argmaps");
const reports = await getCollection("reports");

const argmapBySlug = new Map(argmaps.map((a) => [a.id, a]));
const reportBySlug = new Map(reports.map((r) => [r.id, r]));

type EnrichedArticle = ArticleSpec & {
  hasReport: boolean;
  hasArgmap: boolean;
  reportHref?: string;
  argmapHref?: string;
  formalExpression?: string;
};

const enriched: EnrichedArticle[] = articles.map((a) => {
  const report = reportBySlug.get(a.slug);
  const argmap = argmapBySlug.get(a.slug);
  return {
    ...a,
    hasReport: !!report,
    hasArgmap: !!argmap,
    reportHref: report ? `/reports/${report.id}/` : undefined,
    argmapHref: argmap ? `/argmaps/${argmap.id}/` : undefined,
    formalExpression: argmap?.data.coreThesis.formal?.expression?.trim().split("\n")[0],
  };
});

const byPart = (id: 1 | 2 | 3 | 4 | 5) => enriched.filter((a) => a.part === id);

// ── 跨文章概念連結（formal logic 同構與遞迴） ──────────────────
type CrossLink = { from: string; to: string[]; label: string; formal: string };
const crossLinks: CrossLink[] = [
  {
    from: "01",
    to: ["02"],
    label: "V₁..V₆ 程序防火牆 ⊑ M₄ 隱私衡量",
    formal: "article_01.{V₁..V₆}  ⊨  article_02.M₄.subspec",
  },
  {
    from: "02",
    to: ["01", "03", "04", "05", "06", "07", "08", "13", "15", "16", "17"],
    label: "𝒩(M₁..M₄) 規範矩陣是貫穿全系列的母骨架",
    formal: "∀ article_i ∈ {01..19} : ∃ Mⱼ : refines(article_i, Mⱼ)",
  },
  {
    from: "03",
    to: ["04", "05"],
    label: "合取必要條件 W₁∧W₂∧W₃ ≅ T₁∧T₂∧T₃ ≅ ¬∃IT' 三維張力",
    formal: "isomorphic(article_03.H1', article_04.T, article_05.IT')",
  },
  {
    from: "04",
    to: ["06", "07", "14"],
    label: "T_Remedy 救濟條款 → CB-Justice D₂* + MR-CivicProof R₃R₄ + 跨法域救濟空白",
    formal: "T_Remedy ⊨ {D₂*, R₃, R₄, redress_gap}",
  },
  {
    from: "07",
    to: ["08"],
    label: "主權前提 SRP ↔ 歷史前提 HM 的對偶（同為類別失敗論證）",
    formal: "dual(SRP : sovereignty_container, HM : historical_precondition)",
  },
  {
    from: "06",
    to: ["11", "15"],
    label: "Rawls 辭典序 D₁* + Anderson 民主公民身分 D₂* → essential facility + inclusion rights",
    formal: "{D₁*, D₂*} ⊨ {essential_facility, inclusion_rights}",
  },
  {
    from: "05",
    to: ["12", "13"],
    label: "IT' 不可能三角 → no-phone-home 工程經濟學 + 結構性滑坡預防",
    formal: "IT'(U, D, I)  ⇒  {no_phone_home, slippage_prevention}.constraints",
  },
  {
    from: "11",
    to: ["18"],
    label: "Essential facility doctrine ↔ Selective disclosure UX 認知極限",
    formal: "essential_facility ∧ ¬cognitive_load_ok  ⇒  ¬accessible(UX)",
  },
];

const partColors: Record<1 | 2 | 3 | 4 | 5, string> = {
  1: "color-mix(in oklab, var(--color-accent) 18%, var(--color-bg))",
  2: "color-mix(in oklab, #d4a373 22%, var(--color-bg))",
  3: "color-mix(in oklab, #8a7090 22%, var(--color-bg))",
  4: "color-mix(in oklab, #5b8a72 22%, var(--color-bg))",
  5: "color-mix(in oklab, #c97f5a 22%, var(--color-bg))",
};

const stats = {
  total: articles.length,
  reports: enriched.filter((a) => a.hasReport).length,
  argmaps: enriched.filter((a) => a.hasArgmap).length,
};
---

<BaseLayout title="公民證明 19 篇論證地圖" description="From State Credentials to Civic Proofs — 19 篇博士論文文章的母命題、子論證、跨文章概念連結。">
  <article class="map-page">
    <header class="map-page__header">
      <p class="map-page__kicker">Master Argument Map</p>
      <h1 class="map-page__title">公民證明 19 篇論證地圖</h1>
      <p class="map-page__subtitle">
        From State Credentials to Civic Proofs — Rebuilding Democratic Trust through Digital Identity
      </p>

      <div class="map-page__thesis">
        <p class="map-page__thesis-label">Central Thesis</p>
        <p class="map-page__thesis-body">
          民主社會所需要的「公民證明」（civic proof），不需要以前置的全量身分識別為前提；
          可問責性是一種<em>結果性條件</em>，而非<em>前置性條件</em>。
          把身分系統從「發證者中心」轉為「持有者中心 + 多層信任」是必要的，
          但若沒有相應的規範底線、平台反壟斷與救濟機制，
          這個轉換會把民主成本下放給最弱勢的使用者。
        </p>
        <pre class="map-page__formal"><code>CivicProof ≜ ⟨ 𝒩, ℱ, ℬ ⟩
A ⇐ P[U]   where   U valid ⇔ V₁ ∧ V₂ ∧ V₃ ∧ V₄ ∧ V₅ ∧ V₆
∀ article_i ∈ &#123;01..19&#125; : ∃ component ∈ &#123;𝒩, ℱ, ℬ&#125; : refines(article_i, component)</code></pre>
      </div>

      <div class="map-page__stats">
        <span><strong>{stats.total}</strong> 篇</span>
        <span><strong>{stats.reports}</strong> 已發</span>
        <span><strong>{stats.argmaps}</strong> 已 argmap</span>
        <span><strong>{stats.total - stats.reports}</strong> 排程</span>
      </div>
    </header>

    {parts.map((part) => {
      const items = byPart(part.id);
      return (
        <section class="map-part" data-part={part.id} style={`--part-tint: ${partColors[part.id]};`}>
          <header class="map-part__header">
            <p class="map-part__label">{part.label}</p>
            <h2 class="map-part__title">{part.title}</h2>
            <p class="map-part__thesis">{part.thesis}</p>
          </header>

          <ol class="map-part__grid">
            {items.map((a) => (
              <li class="map-card" data-status={a.hasReport ? (a.hasArgmap ? "argmap" : "report") : "scheduled"}>
                <header class="map-card__top">
                  <span class="map-card__no">#{a.no}</span>
                  <span class="map-card__prompt">{a.prompt}</span>
                  <span class="map-card__chapter">{a.chapter}</span>
                </header>
                <h3 class="map-card__title">{a.title}</h3>
                {a.formalExpression && (
                  <pre class="map-card__formal"><code>{a.formalExpression}</code></pre>
                )}
                <footer class="map-card__links">
                  {a.reportHref ? (
                    <a class="map-card__link map-card__link--report" href={a.reportHref}>
                      📄 文章
                    </a>
                  ) : (
                    <span class="map-card__link map-card__link--scheduled">📄 排程中</span>
                  )}
                  {a.argmapHref ? (
                    <a class="map-card__link map-card__link--argmap" href={a.argmapHref}>
                      ◇ argmap
                    </a>
                  ) : (
                    <span class="map-card__link map-card__link--scheduled">◇ 待補</span>
                  )}
                </footer>
              </li>
            ))}
          </ol>
        </section>
      );
    })}

    {/* ── 跨文章概念連結 ─────────────────────────── */}
    <section class="map-cross">
      <header class="map-cross__header">
        <p class="map-cross__label">Concept Connections</p>
        <h2 class="map-cross__title">跨文章概念連結</h2>
        <p class="map-cross__intro">
          公民證明不是 19 個獨立論題，而是 ⟨𝒩, ℱ, ℬ⟩ 在不同子問題上的展開。下表標出文章間 formal logic
          同構、遞迴、對偶與構成的關係。
        </p>
      </header>

      <ul class="map-cross__list">
        {crossLinks.map((link) => {
          const fromArticle = enriched.find((a) => a.no === link.from);
          const toArticles = link.to
            .map((n) => enriched.find((a) => a.no === n))
            .filter((a): a is EnrichedArticle => !!a);
          return (
            <li class="map-cross__item">
              <div class="map-cross__row">
                <span class="map-cross__from">
                  {fromArticle?.argmapHref ? (
                    <a href={fromArticle.argmapHref}>#{link.from} {fromArticle?.title}</a>
                  ) : (
                    <span>#{link.from} {fromArticle?.title}</span>
                  )}
                </span>
                <span class="map-cross__arrow">⇒</span>
                <span class="map-cross__to">
                  {toArticles.map((t, i) => (
                    <>
                      {i > 0 && ", "}
                      {t.argmapHref ? (
                        <a href={t.argmapHref}>#{t.no}</a>
                      ) : t.reportHref ? (
                        <a href={t.reportHref}>#{t.no}</a>
                      ) : (
                        <span class="map-cross__pending">#{t.no}</span>
                      )}
                    </>
                  ))}
                </span>
              </div>
              <p class="map-cross__label-text">{link.label}</p>
              <pre class="map-cross__formal"><code>{link.formal}</code></pre>
            </li>
          );
        })}
      </ul>
    </section>

    <footer class="map-foot">
      <p>
        本地圖隨論文系列同步更新。每當一篇 article 發佈，對應的 argmap 將補入；
        新章節的核心公式將顯示於文章卡片內。
      </p>
      <p class="map-foot__lineage">
        Lineage: dissertation-outline.md v1（2026-05-02）→ argmap v2（formal logic + transitions + role/pivot）→ master map（19 articles + 5 mother propositions）
      </p>
    </footer>
  </article>
</BaseLayout>

<style>
  .map-page {
    width: min(96%, 1180px);
    margin: 0 auto var(--space-10);
    position: relative;
    z-index: 2;
    padding-top: var(--space-6, 2rem);
    padding-bottom: var(--space-9, 6rem);
    color: var(--color-ink);
  }

  /* ── Header ─────────────────────────────────────────── */
  .map-page__header { margin-bottom: var(--space-8, 4rem); }
  .map-page__kicker {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    color: var(--color-ink-muted);
    margin: 0 0 var(--space-3);
  }
  .map-page__title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(2.4rem, 5vw, 4rem);
    line-height: 1.08;
    letter-spacing: var(--tracking-tight);
    margin: 0 0 var(--space-3);
  }
  .map-page__subtitle {
    font-family: var(--font-mono);
    font-size: 0.92rem;
    color: var(--color-ink-muted);
    margin: 0 0 var(--space-6);
  }

  .map-page__thesis {
    border-left: 3px solid var(--color-accent);
    padding: var(--space-4) var(--space-5);
    background: color-mix(in oklab, var(--color-accent) 8%, var(--color-bg));
    margin-bottom: var(--space-5);
    border-radius: 4px;
  }
  .map-page__thesis-label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    color: var(--color-ink-muted);
    margin: 0 0 var(--space-2);
  }
  .map-page__thesis-body {
    font-family: var(--font-display);
    font-size: 1.05rem;
    line-height: 1.7;
    margin: 0 0 var(--space-3);
  }
  .map-page__formal {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    line-height: 1.7;
    background: color-mix(in oklab, var(--color-ink) 6%, var(--color-bg));
    padding: var(--space-3) var(--space-4);
    border-radius: 3px;
    overflow-x: auto;
    margin: 0;
    color: var(--color-ink);
  }

  .map-page__stats {
    display: flex;
    gap: var(--space-5);
    flex-wrap: wrap;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--color-ink-muted);
  }
  .map-page__stats strong { color: var(--color-accent); font-size: 1rem; }

  /* ── Parts ───────────────────────────────────────────── */
  .map-part {
    margin-bottom: var(--space-8, 4rem);
    padding: var(--space-5) var(--space-5);
    background: var(--part-tint);
    border-radius: 6px;
  }
  .map-part__header { margin-bottom: var(--space-5); }
  .map-part__label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    color: var(--color-accent);
    margin: 0 0 var(--space-2);
    font-weight: 600;
  }
  .map-part__title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(1.4rem, 2.5vw, 1.9rem);
    line-height: 1.2;
    margin: 0 0 var(--space-2);
  }
  .map-part__thesis {
    font-family: var(--font-display);
    font-size: 0.98rem;
    line-height: 1.65;
    color: var(--color-ink);
    margin: 0;
    max-width: 72ch;
  }

  .map-part__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: var(--space-3);
    margin: 0;
    padding: 0;
    list-style: none;
  }

  /* ── Cards ───────────────────────────────────────────── */
  .map-card {
    background: var(--color-bg);
    border: 1px solid color-mix(in oklab, var(--color-ink) 12%, transparent);
    border-radius: 4px;
    padding: var(--space-3) var(--space-4);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    transition: transform 0.15s ease, border-color 0.15s ease;
  }
  .map-card:hover {
    transform: translateY(-2px);
    border-color: var(--color-accent);
  }
  .map-card[data-status="scheduled"] {
    opacity: 0.62;
    background: color-mix(in oklab, var(--color-bg) 95%, var(--color-ink-muted));
  }
  .map-card[data-status="report"] {
    border-left: 3px solid color-mix(in oklab, var(--color-accent) 50%, var(--color-bg));
  }
  .map-card[data-status="argmap"] {
    border-left: 3px solid var(--color-accent);
  }

  .map-card__top {
    display: flex;
    gap: var(--space-2);
    align-items: baseline;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--color-ink-muted);
  }
  .map-card__no { font-weight: 700; color: var(--color-accent); font-size: 0.85rem; }
  .map-card__prompt {
    background: color-mix(in oklab, var(--color-ink) 10%, transparent);
    padding: 1px 6px;
    border-radius: 2px;
  }
