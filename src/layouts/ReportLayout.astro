---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import AuroraBackground from "../components/AuroraBackground.astro";
import ReadingProgress from "../components/ReadingProgress.astro";
import TableOfContents from "../components/TableOfContents.astro";
import AiMetaBadge from "../components/AiMetaBadge.astro";
import ScrollReveal from "../components/ScrollReveal.astro";
import CitationTooltip from "../components/CitationTooltip.astro";
import { formatDate } from "../utils/date";
import { readingTime } from "../utils/reading-time";
import { withBase } from "../utils/paths";
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  tags: string[];
  headings: { depth: number; slug: string; text: string }[];
  body: string;
  aiModel?: string;
  aiPrompt?: string;
  aiGeneratedDate?: Date;
  humanReviewed?: boolean;
}

const {
  title,
  description,
  pubDate,
  updatedDate,
  tags,
  headings,
  body,
  aiModel,
  aiPrompt,
  aiGeneratedDate,
  humanReviewed,
} = Astro.props;
---

<!doctype html>
<html lang="zh-TW">
  <head>
    <BaseHead title={title} description={description} />
  </head>
  <body class="min-h-screen flex flex-col">
    <AuroraBackground />
    <ReadingProgress />
    <Header />

    <main class="flex-1 max-w-6xl mx-auto w-full px-4 py-8">
      <div class="lg:grid lg:grid-cols-[1fr_220px] lg:gap-8">
        <!-- Article -->
        <article class="max-w-[72ch] mx-auto">
          <!-- Header -->
          <header class="mb-8">
            <h1 class="text-3xl md:text-4xl font-bold font-serif text-[var(--color-text)] leading-tight mb-4">
              {title}
            </h1>
            <div class="flex flex-wrap items-center gap-3 text-sm text-[var(--color-text-muted)]">
              <time datetime={pubDate.toISOString()}>{formatDate(pubDate)}</time>
              {updatedDate && (
                <span>（更新於 {formatDate(updatedDate)}）</span>
              )}
              <span class="opacity-40">|</span>
              <span>{readingTime(body)}</span>
            </div>

            {tags.length > 0 && (
              <div class="flex flex-wrap gap-2 mt-4">
                {tags.map((tag) => (
                  <a
                    href={withBase(`/tags/${tag}/`)}
                    class="text-xs px-2.5 py-0.5 rounded-full border
                           border-[var(--color-border)] text-[var(--color-text-muted)]
                           hover:border-[var(--color-accent)]/40 hover:text-[var(--color-accent)]
                           transition-colors"
                  >
                    {tag}
                  </a>
                ))}
              </div>
            )}
          </header>

          <AiMetaBadge
            aiModel={aiModel}
            aiPrompt={aiPrompt}
            aiGeneratedDate={aiGeneratedDate}
            humanReviewed={humanReviewed}
          />

          <!-- Content -->
          <div class="report-prose">
            <slot />
          </div>

          <!-- Back -->
          <div class="mt-16 pt-8 border-t border-[var(--color-border)]">
            <a
              href={withBase("/")}
              class="inline-flex items-center gap-2 text-sm text-[var(--color-text-muted)]
                     hover:text-[var(--color-accent)] transition-colors"
            >
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path d="M15 19l-7-7 7-7"></path>
              </svg>
              返回報告列表
            </a>
          </div>
        </article>

        <!-- Sidebar TOC -->
        <aside>
          <TableOfContents headings={headings} />
        </aside>
      </div>
    </main>

    <Footer />
    <ScrollReveal />
    <CitationTooltip />
  </body>
</html>
